# Override global gitignore (~/.gitignore_global) for this repo.
# The global config ignores agent-skill scaffolding so it doesn't get committed
# by default; here we want it tracked. Negations re-include those paths.

# Top-level scaffolding files
!CLAUDE.md
!AGENTS.md
!CONTEXT.md
!CONTEXT-MAP.md

# Scaffolding directories (re-include the dir, then its contents)
!docs/agents/
!docs/agents/**
!docs/adr/
!docs/adr/**
!.scratch/
!.scratch/**

# Scaffolding scripts
!scripts/issues-map.sh

# Defense-in-depth: the commit signing key (id_ed25519_signing) is generated in
# ~/.ssh and never lives in the repo — but never let its private half in if copied
# here by accident. The PUBLIC allowed_signers / .pub are non-secret and stay tracked.
id_ed25519_signing
